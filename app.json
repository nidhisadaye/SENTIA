{
  "expo": {
    "name": "SentiaApp",
    "slug": "sentia-app-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sentia-icon-fitted.png",
    "scheme": "sentiaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "Sentia uses motion data to detect steps and provide real-time navigation assistance for visually impaired users.",
        "NSCameraUsageDescription": "Sentia uses the camera to help visually impaired users understand their surroundings.",
        "NSMicrophoneUsageDescription": "Allow access to microphone for voice commands",
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSLocationWhenInUseUsageDescription": "Allow Sentia to access your location."
      }
    },
    "android": {
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/sentia-icon-fitted.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sentia.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sentia-splash-fitted.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow access to microphone for voice commands"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sentia to access your location.",
           "speechRecognitionPermission": "Allow Sentia to understand spoken commands."
        }
      ]

    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "groqKey": "",
      "openRouterKey": "",
      "googleMapsExpoKey": "",
      "googleMapsEasKey": "",
      "useEasGoogleMapsKey": true,
      "proxyBaseUrl": "",
      "roboflowApiKey": "",
      "roboflowModelId": "",
      "router": {},
      "eas": {
        "projectId": "659dad7a-bda9-436a-8197-f68c555f9439"
      }
    },
    "owner": "nidhi_sadaye"
  }
}
